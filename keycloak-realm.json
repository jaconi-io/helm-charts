  ],
  "users": [
    {
      "credentials": [
        {
          "type": "password",
          "value": "admin"
        }
      ],
      "email": "admin@jaconi.io",
      "enabled": true,
      "firstName": "Jaconi",
      "lastName": "Admin",
      "username": "admin"
    },
    {
      "username": "service-account-netbird-management",
